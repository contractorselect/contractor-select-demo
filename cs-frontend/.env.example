# =============================================================================
# ContractorSelect.me — Demo App Environment Variables
# =============================================================================
#
# All variables in this file are OPTIONAL for the demo. The app boots with
# zero configuration and runs entirely on mock data. Set these only if you
# want to exercise specific real integrations.
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For Vercel: set these in the project's Environment Variables panel.
# =============================================================================


# ----- Stripe (OPTIONAL) -----
# When unset, the payment screen shows a "Simulate Payment & Unlock (demo)"
# button that skips Stripe and navigates directly to the unlocked view.
# When set with a real Stripe publishable key, the payment modal uses real
# Stripe Elements (PaymentElement) — but note that the dev MOCK_CLIENT_SECRET
# in code will not work; you'd need a real backend endpoint to issue secrets.
#
# Get a test key from: https://dashboard.stripe.com/test/apikeys
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx


# ----- Backend API URL (FUTURE - not used in demo) -----
# When the frontend is wired to a real backend (Sprint 1+), set this to
# your Railway / Render / etc. backend URL.
# NEXT_PUBLIC_API_URL=https://api.contractorselect.me


# ----- Supabase (FUTURE - not used in demo) -----
# When using Supabase for storage/database in production:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
